---
interface Props {
  html?: string;
  css?: string;
  js?: string;
  title?: string;
}

const {
  html = "",
  css = "",
  js = "",
  title = "Code Preview"
} = Astro.props;

function cleanCode(code: string) {
  if (!code) return "";
  const lines = code.split("\n");
  while (lines.length && lines[0].trim() === "") {
    lines.shift();
  }
  const minIndent = lines.reduce((min, line) => {
    if (line.trim() === "") return min;
    const match = line.match(/^(\s*)/);
    const count = match ? match[1].length : 0;
    return count < min ? count : min;
  }, Infinity);
  return lines
    .map(line => (line.length >= minIndent ? line.slice(minIndent) : line))
    .join("\n")
    .trim();
}

const cleanHtml = cleanCode(html);
const cleanCss = cleanCode(css);
const cleanJs = cleanCode(js);

const scriptStart = "<" + "script>";
const scriptEnd = "</" + "script>";

const iframeSourceCode = `
  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="UTF-8">
      <meta name="color-scheme" content="light dark">
      <style>
        body {
          font-family: system-ui, sans-serif;
          margin: 12px;
          padding: 0;
          color-scheme: light dark;
        }
        ${cleanCss}
      </style>
    </head>
    <body>
      ${cleanHtml}
      ${scriptStart}
        try {
          ${cleanJs}
        } catch (err) {
          console.error(err);
          document.body.innerHTML += '<pre style="color:#ef4444; border:1px solid #fee2e2; background:#fef2f2; padding:12px; border-radius:6px; font-family:monospace; margin-top:12px;">' + err.message + '</pre>';
        }
      ${scriptEnd}
    </body>
  </html>
`;
---

<div class="border border-gray-200 dark:border-gray-700 rounded-lg my-8 overflow-hidden shadow-sm dark:shadow-none not-prose" data-playground>
  {title && (
    <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
      <svg class="w-4 h-4 text-gray-400 dark:text-gray-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
        <path strokeLinecap="round" strokeLinejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
      </svg>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Demo: {title}</span>
    </div>
  )}

  <div class="flex flex-col bg-gray-900 dark:bg-black">
    {cleanHtml && (
      <div class="border-b border-gray-700/50">
        <div class="flex items-center justify-between px-4 py-1.5 bg-gray-800 dark:bg-gray-900">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-400">HTML</span>
          <button class="copy-btn text-xs text-gray-400 bg-gray-700 hover:bg-gray-600 hover:text-gray-200 px-2 py-0.5 rounded transition-colors" data-code={cleanHtml}>Copy</button>
        </div>
        <pre class="m-0 p-4 overflow-x-auto"><code class="text-sm leading-relaxed text-gray-200 font-mono">{cleanHtml}</code></pre>
      </div>
    )}

    {cleanCss && (
      <div class="border-b border-gray-700/50">
        <div class="flex items-center justify-between px-4 py-1.5 bg-gray-800 dark:bg-gray-900">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-400">CSS</span>
          <button class="copy-btn text-xs text-gray-400 bg-gray-700 hover:bg-gray-600 hover:text-gray-200 px-2 py-0.5 rounded transition-colors" data-code={cleanCss}>Copy</button>
        </div>
        <pre class="m-0 p-4 overflow-x-auto"><code class="text-sm leading-relaxed text-gray-200 font-mono">{cleanCss}</code></pre>
      </div>
    )}

    {cleanJs && (
      <div class="border-b border-gray-700/50">
        <div class="flex items-center justify-between px-4 py-1.5 bg-gray-800 dark:bg-gray-900">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-400">JavaScript</span>
          <button class="copy-btn text-xs text-gray-400 bg-gray-700 hover:bg-gray-600 hover:text-gray-200 px-2 py-0.5 rounded transition-colors" data-code={cleanJs}>Copy</button>
        </div>
        <pre class="m-0 p-4 overflow-x-auto"><code class="text-sm leading-relaxed text-gray-200 font-mono">{cleanJs}</code></pre>
      </div>
    )}
  </div>

  <div class="flex flex-col border-t-2 border-gray-200 dark:border-gray-700">
    <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800/50 px-4 py-1.5 border-b border-gray-200 dark:border-gray-700">
      Live Output Window
    </div>
    <iframe
      srcdoc={iframeSourceCode}
      title={title}
      sandbox="allow-scripts"
      loading="lazy"
      class="w-full h-[220px] border-none bg-white dark:bg-gray-900"
    ></iframe>
  </div>
</div>

<script>
  const copyButtons = document.querySelectorAll('[data-playground] .copy-btn');
  copyButtons.forEach(button => {
    button.addEventListener('click', async () => {
      const codeToCopy = button.getAttribute('data-code') || '';
      try {
        await navigator.clipboard.writeText(codeToCopy);
        const originalText = button.textContent;
        button.textContent = 'Copied!';
        button.classList.remove('bg-gray-700', 'hover:bg-gray-600');
        button.classList.add('bg-emerald-600', 'text-white');
        setTimeout(() => {
          button.textContent = originalText;
          button.classList.remove('bg-emerald-600', 'text-white');
          button.classList.add('bg-gray-700', 'hover:bg-gray-600');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy text: ', err);
      }
    });
  });
</script>
