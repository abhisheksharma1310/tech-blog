---
import type { Post } from "../data/posts";
import Header from "../components/Header.tsx";
import Sidebar from "../components/Sidebar.tsx";
import AdBlock from "../components/AdBlock.tsx";
import Footer from "../components/Footer.tsx";
import "../styles/global.css";

const { title, description, posts, activeSlug } = Astro.props as {
  title: string;
  description: string;
  posts: Post[];
  activeSlug?: string;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      id="prism-theme"
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
    />
  </head>
  <body class="bg-white dark:bg-[#0a0a0a] text-black dark:text-white antialiased min-h-screen flex flex-col">
    <Header />
    <div class="flex-1">
      <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-[240px_1fr_200px] lg:gap-8">
          <aside class="hidden lg:block border-r border-gray-200 dark:border-gray-800 min-h-screen pr-6">
            <Sidebar posts={posts} activeSlug={activeSlug} />
          </aside>
          <main class="min-w-0 py-6 lg:py-10">
            <slot />
          </main>
          <aside class="hidden lg:block border-l border-gray-200 dark:border-gray-800 min-h-screen pl-6">
            <AdBlock />
          </aside>
        </div>
      </div>
    </div>
    <Footer />

    <!-- Mobile sidebar overlay -->
    <div id="mobile-sidebar" class="mobile-sidebar-overlay">
      <div class="mobile-sidebar-backdrop" />
      <div class="mobile-sidebar-panel">
        <div class="flex items-center justify-between px-4 h-16 border-b border-gray-200 dark:border-gray-800">
          <span class="text-sm font-semibold text-black dark:text-white">Courses</span>
          <button
            id="mobile-sidebar-close"
            type="button"
            class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400"
            aria-label="Close menu"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
              <path strokeLinecap="round" strokeLinejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="overflow-y-auto h-[calc(100vh-4rem)] px-2">
          <Sidebar posts={posts} activeSlug={activeSlug} onLinkClick={() => document.body.classList.remove('mobile-sidebar-open')} />
        </div>
      </div>
    </div>

    <script>
      (function () {
        var root = document.documentElement;

        // --- Theme ---
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme = stored || (prefersDark ? "dark" : "light");
        root.classList.toggle("dark", theme === "dark");

        //var prismLink = document.getElementById("prism-theme");
        // if (prismLink) {
        //   prismLink.href = theme === "dark"
        //     ? "https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
        //     : "https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css";
        // }

        var themeBtn = document.getElementById("theme-toggle");
        if (themeBtn) {
          themeBtn.addEventListener("click", function () {
            var isDark = root.classList.contains("dark");
            root.classList.toggle("dark", !isDark);
            localStorage.setItem("theme", !isDark ? "dark" : "light");
            // if (prismLink) {
            //   prismLink.href = !isDark
            //     ? "https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
            //     : "https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css";
            // }
          });
        }

        // --- Mobile sidebar ---
        function openSidebar() { document.body.classList.add('mobile-sidebar-open'); }
        function closeSidebar() { document.body.classList.remove('mobile-sidebar-open'); }

        var menuBtn = document.getElementById("mobile-menu-btn");
        if (menuBtn) menuBtn.addEventListener("click", openSidebar);

        var closeBtn = document.getElementById("mobile-sidebar-close");
        if (closeBtn) closeBtn.addEventListener("click", closeSidebar);

        var backdrop = document.querySelector(".mobile-sidebar-backdrop");
        if (backdrop) backdrop.addEventListener("click", closeSidebar);

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") closeSidebar();
        });
      })();
    </script>
  </body>
</html>
