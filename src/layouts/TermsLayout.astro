---
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import '../styles/global.css';

const { title, description } = Astro.props as {
  title: string;
  description: string;
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-white dark:bg-[#0a0a0a] text-black dark:text-white antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
        <div class="max-w-prose mx-auto prose-custom">
          <slot />
        </div>
      </div>
    </main>
    <Footer />

    <script>
      (function () {
        var root = document.documentElement;
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        root.classList.toggle('dark', theme === 'dark');

        var themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          themeBtn.addEventListener('click', function () {
            var isDark = root.classList.contains('dark');
            root.classList.toggle('dark', !isDark);
            localStorage.setItem('theme', !isDark ? 'dark' : 'light');
          });
        }
      })();
    </script>
  </body>
</html>
