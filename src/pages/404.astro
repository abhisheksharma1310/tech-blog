---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { getPosts } from '../data/posts';

const posts = await getPosts();
const title = 'Page Not Found - LearnCode.live';
const description = 'The page you were looking for does not exist. Find the latest tutorials about web development, programming, cloud computing, and embedded/IoT.';
---
<BaseLayout title={title} description={description} posts={posts}>
  <SEO title={title} description={description} />

  <section class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-16 h-16 rounded-2xl bg-brand-green/10 dark:bg-brand-green/20 flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
        <path strokeLinecap="round" strokeLinejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
    </div>
    <h1 class="text-heading-1 text-black dark:text-white mb-3">404</h1>
    <p class="text-heading-4 text-gray-500 dark:text-gray-400 mb-2">Page not found</p>
    <p class="text-sm text-gray-400 dark:text-gray-500 max-w-md mb-8">
      The page you are looking for doesn't exist or has been moved. Browse our latest tutorials below or return to the homepage.
    </p>
    <a href="/" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-black dark:bg-brand-green dark:text-black rounded-full hover:bg-gray-800 dark:hover:bg-brand-green-deep transition-colors">
      Back to Home
      <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
        <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </section>
</BaseLayout>
