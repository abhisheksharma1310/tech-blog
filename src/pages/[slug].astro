---
import BaseLayout from "../layouts/BaseLayout.astro";
import SEO from "../components/SEO.astro";
import { getPosts } from "../data/posts";
import CodePlayground from "@/components/CodePlayground.astro";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const posts = await getPosts();
const slug = Astro.params.slug as string;
const post = posts.find((p) => p.slug === slug);

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { Content } = await post.render();
const { data: frontmatter } = post;

const title = `${frontmatter.title} · learncode.live`;
const description = frontmatter.description;

const categoryKey = (p: any) => p.data.category.join("|");
const currentCategoryKey = categoryKey(post);
const sameCategoryPosts = posts.filter((item) => categoryKey(item) === currentCategoryKey);

const currentIndex = sameCategoryPosts.findIndex((item) => item.slug === slug);
const previousPost = currentIndex > 0 ? sameCategoryPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sameCategoryPosts.length - 1 ? sameCategoryPosts[currentIndex + 1] : null;

const cleanUrl = `/${post.slug}`;
---

<BaseLayout title={title} description={description} posts={posts} activeSlug={slug}>
  <SEO title={title} description={description} canonical={`https://learncode.live${cleanUrl}`} />

  <article>
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-black dark:hover:text-white transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
        <path strokeLinecap="round" strokeLinejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
      <span class="text-gray-500 dark:text-gray-400">{frontmatter.category.join(" / ")}</span>
    </nav>

    <!-- Post Header -->
    <!-- <header class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-xs font-medium text-brand-green bg-brand-green/10 dark:bg-brand-green/20 px-2.5 py-1 rounded-full">
          {frontmatter.category.join(" / ")}
        </span>
        {frontmatter.tags.slice(0, 2).map((tag: string) => (
          <span class="text-xs text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-white/5 px-2 py-1 rounded-md border border-gray-200 dark:border-gray-800">
            {tag}
          </span>
        ))}
        <span class="text-xs text-gray-400 dark:text-gray-500 ml-auto">{frontmatter.date}</span>
      </div>
      <h1 class="text-heading-2 sm:text-heading-1 text-black dark:text-white mb-4">{frontmatter.title}</h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed">{frontmatter.description}</p>
      <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-200 dark:border-gray-800">
        <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center text-xs font-bold text-brand-green-deep dark:text-brand-green">
          {frontmatter.author.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
        </div>
        <div class="text-sm text-gray-500 dark:text-gray-400">
          <span class="font-medium text-black dark:text-white">{frontmatter.author}</span>
        </div>
      </div>
    </header> -->

    <!-- Chapter Navigation (Top) -->
    <nav class="flex items-center justify-between mb-8 p-4 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50/50 dark:bg-white/[0.02]" aria-label="Chapter navigation">
      {previousPost ? (
        <a href={`/${previousPost.slug}`} class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors group">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <span class="hidden sm:inline">Previous</span>
          <span class="hidden lg:inline text-black dark:text-white font-medium truncate max-w-[200px]">{previousPost.data.title}</span>
        </a>
      ) : <div />}

      <span class="text-xs text-gray-400 dark:text-gray-500">
        {currentIndex + 1} / {sameCategoryPosts.length}
      </span>

      {nextPost ? (
        <a href={`/${nextPost.slug}`} class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors group text-right">
          <span class="hidden lg:inline text-black dark:text-white font-medium truncate max-w-[200px]">{nextPost.data.title}</span>
          <span class="hidden sm:inline">Next</span>
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      ) : <div />}
    </nav>

    <!-- Content -->
    <div class="prose-custom">
      <Content components={{ CodePlayground }} />
    </div>

    <!-- Chapter Navigation (Bottom) -->
    <nav class="flex items-center justify-between mt-12 p-4 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50/50 dark:bg-white/[0.02]" aria-label="Chapter navigation">
      {previousPost ? (
        <a href={`/${previousPost.slug}`} class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <div class="text-left">
            <div class="text-xs text-gray-400 dark:text-gray-500">Previous</div>
            <div class="font-medium text-black dark:text-white truncate max-w-[200px]">{previousPost.data.title}</div>
          </div>
        </a>
      ) : <div />}

      {nextPost ? (
        <a href={`/${nextPost.slug}`} class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors text-right">
          <div>
            <div class="text-xs text-gray-400 dark:text-gray-500">Next</div>
            <div class="font-medium text-black dark:text-white truncate max-w-[200px]">{nextPost.data.title}</div>
          </div>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      ) : <div />}
    </nav>
  </article>
</BaseLayout>
