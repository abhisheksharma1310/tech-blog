---
// src/pages/[slug].astro
import BaseLayout from "../layouts/BaseLayout.astro";
import SEO from "../components/SEO.astro";
import { getPosts, getPostsMetadata } from "../data/posts"; // Imported metadata helper
import CodePlayground from "@/components/CodePlayground.astro";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const posts = await getPosts();
const postsMetadata = await getPostsMetadata(); // FIX: Fetch clean metadata array here
const slug = Astro.params.slug as string;
const post = posts.find((p) => p.slug === slug);

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { Content } = await post.render();
const { data: frontmatter } = post;

const title = `${frontmatter.title} · learncode.live`;
const description = frontmatter.description;

const categoryKey = (p: any) => p.data.category.join("|");
const currentCategoryKey = categoryKey(post);
const sameCategoryPosts = posts.filter(
  (item) => categoryKey(item) === currentCategoryKey,
);

const currentIndex = sameCategoryPosts.findIndex((item) => item.slug === slug);
const previousPost =
  currentIndex > 0 ? sameCategoryPosts[currentIndex - 1] : null;
const nextPost =
  currentIndex < sameCategoryPosts.length - 1
    ? sameCategoryPosts[currentIndex + 1]
    : null;

const cleanUrl = `/${post.slug}`;
---

<!-- FIX: Changed posts={posts} to posts={postsMetadata} -->
<BaseLayout
  title={title}
  description={description}
  posts={postsMetadata}
  activeSlug={slug}
>
  <SEO
    title={title}
    description={description}
    canonical={`https://learncode.live${cleanUrl}`}
  />

  <article>
    <!-- Breadcrumb -->
    <nav
      class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-6"
      aria-label="Breadcrumb"
    >
      <a
        href="/"
        class="hover:text-black dark:hover:text-white transition-colors">Home</a
      >
      <svg
        class="w-3 h-3"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        strokeWidth={2}
      >
        <path
          strokeLinecap="round"
          strokeLinejoin="round"
          d="m8.25 4.5 7.5 7.5-7.5 7.5"></path>
      </svg>
      <span class="text-gray-500 dark:text-gray-400"
        >{frontmatter.category.join(" / ")}</span
      >
    </nav>

    <!-- Chapter Navigation (Top) -->
    <nav
      class="flex items-center justify-between mb-8 p-4 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50/50 dark:bg-white/[0.02]"
      aria-label="Chapter navigation"
    >
      {
        previousPost ? (
          <a
            href={`/${previousPost.slug}`}
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors group"
          >
            <svg
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              strokeWidth={2}
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
              />
            </svg>
            <span class="hidden sm:inline">Previous</span>
            <span class="hidden lg:inline text-black dark:text-white font-medium truncate max-w-[200px]">
              {previousPost.data.title}
            </span>
          </a>
        ) : (
          <div />
        )
      }

      <span class="text-xs text-gray-400 dark:text-gray-500">
        {currentIndex + 1} / {sameCategoryPosts.length}
      </span>

      {
        nextPost ? (
          <a
            href={`/${nextPost.slug}`}
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors group text-right"
          >
            <span class="hidden lg:inline text-black dark:text-white font-medium truncate max-w-[200px]">
              {nextPost.data.title}
            </span>
            <span class="hidden sm:inline">Next</span>
            <svg
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              strokeWidth={2}
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
              />
            </svg>
          </a>
        ) : (
          <div />
        )
      }
    </nav>

    <!-- Content -->
    <div class="prose-custom">
      <Content components={{ CodePlayground }} />
    </div>

    <!-- Chapter Navigation (Bottom) -->
    <nav
      class="flex items-center justify-between mt-12 p-4 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50/50 dark:bg-white/[0.02]"
      aria-label="Chapter navigation"
    >
      {
        previousPost ? (
          <a
            href={`/${previousPost.slug}`}
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              strokeWidth={2}
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
              />
            </svg>
            <div class="text-left">
              <div class="text-xs text-gray-400 dark:text-gray-500">
                Previous
              </div>
              <div class="font-medium text-black dark:text-white truncate max-w-[200px]">
                {previousPost.data.title}
              </div>
            </div>
          </a>
        ) : (
          <div />
        )
      }

      <span class="text-xs text-gray-400 dark:text-gray-500">
        {currentIndex + 1} / {sameCategoryPosts.length}
      </span>

      {
        nextPost ? (
          <a
            href={`/${nextPost.slug}`}
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors text-right"
          >
            <div>
              <div class="text-xs text-gray-400 dark:text-gray-500">Next</div>
              <div class="font-medium text-black dark:text-white truncate max-w-[200px]">
                {nextPost.data.title}
              </div>
            </div>
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              strokeWidth={2}
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
              />
            </svg>
          </a>
        ) : (
          <div />
        )
      }
    </nav>
  </article>
</BaseLayout>
