---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ArticleCard from '../../components/ArticleCard.tsx';
import { getPosts } from '../../data/posts';

const posts = getPosts();
const title = 'All Posts · Tech Blog';
const description = 'Browse every article in the Tech Blog, organized by category and optimized for static deployment.';
---
<BaseLayout title={title} description={description} posts={posts}>
  <SEO title={title} description={description} />
  <section class="hero">
    <h2>Complete article archive</h2>
    <p>Find the latest writing about cloud, web development, embedded systems, DevOps, and aptitude in one easy-to-scan blog.</p>
  </section>
  <section class="post-grid">
    {posts.map((post) => <ArticleCard key={post.slug} post={post} />)}
  </section>
</BaseLayout>
