---
import SEO from '../components/SEO.astro';
import TermsLayout from '@/layouts/TermsLayout.astro';

const title = 'Contact Us - LearnCode.live';
const description = "Have a question, suggestion, or partnership idea? We'd love to hear from you. Contact the LearnCode.live team.";
---
<TermsLayout title={title} description={description}>
  <SEO title={title} description={description} />

  <section>
    <h1 class="text-heading-1 text-black dark:text-white mb-4">Contact Us</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-10">
      Have a question, suggestion, or partnership idea? We'd love to hear from you.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-10">
      <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 text-center">
        <div class="w-10 h-10 rounded-full bg-brand-green/10 flex items-center justify-center mx-auto mb-3">
          <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-black dark:text-white mb-1">Email</h3>
        <a href="mailto:contact@learncode.live" class="text-sm text-brand-green-deep dark:text-brand-green hover:underline">
          contact@learncode.live
        </a>
      </div>

      <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 text-center">
        <div class="w-10 h-10 rounded-full bg-brand-green/10 flex items-center justify-center mx-auto mb-3">
          <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-black dark:text-white mb-1">Website</h3>
        <a href="https://www.learncode.live" class="text-sm text-brand-green-deep dark:text-brand-green hover:underline">
          www.learncode.live
        </a>
      </div>

      <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 text-center">
        <div class="w-10 h-10 rounded-full bg-brand-green/10 flex items-center justify-center mx-auto mb-3">
          <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5m6 4.125 2.25 2.25m0 0 2.25 2.25M12 11.625l2.25-2.25M12 11.625l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-black dark:text-white mb-1">Coding Lab</h3>
        <a href="https://lab.learncode.live" target="_blank" class="text-sm text-brand-green-deep dark:text-brand-green hover:underline">
          lab.learncode.live
        </a>
      </div>
    </div>

    <!-- <form class="max-w-lg border border-gray-200 dark:border-gray-800 rounded-xl p-6 space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium text-black dark:text-white mb-1">Name</label>
        <input type="text" id="name" class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-md bg-white dark:bg-transparent text-black dark:text-white placeholder:text-gray-400 dark:placeholder:text-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors" placeholder="Your name" />
      </div>
