---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import ArticleCard from '@/components/ArticleCard.tsx';
import { getPosts } from '../data/posts';

const posts = await getPosts();
const title = 'LearnCode.live - Interactive Tech Tutorials & Programming Resources';
const description = 'Master programming, web development, DSA, cloud computing, and embedded/IoT with interactive tutorials, quizzes, exercises, and cheatsheets.';

const categories = [
  { name: 'Web Development', slug: 'web', count: posts.filter(p => p.data.category[0] === 'web').length, desc: 'HTML, CSS, JavaScript, React, Node.js, and modern web frameworks.', icon: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z' },
  { name: 'Programming', slug: 'programming', count: posts.filter(p => p.data.category[0] === 'programming').length, desc: 'C, C++, JavaScript, Python, DSA fundamentals and problem-solving.', icon: 'M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z' },
  { name: 'Embedded & IoT', slug: 'emb-iot', count: posts.filter(p => p.data.category[0] === 'emb-iot').length, desc: 'Arduino, ESP32, sensors, actuators, and embedded systems programming.', icon: 'M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Z' },
];

const stats = [
  { value: '300+', label: 'Tutorials' },
  { value: '10+', label: 'Courses' },
  { value: 'Free', label: 'Always' },
  { value: '100%', label: 'Hands-on' },
];
---
<BaseLayout title={title} description={description} posts={posts}>
  <SEO title={title} description={description} />

  <!-- Hero -->
  <section class="relative overflow-hidden mb-16 lg:mb-24">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-green/5 via-transparent to-blue-50 dark:from-brand-green/10 dark:via-transparent dark:to-transparent pointer-events-none" />
    <div class="relative py-12 lg:py-20 text-center">
      <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-green/10 border border-brand-green/20 text-sm text-brand-green-deep dark:text-brand-green font-medium mb-6">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
          <path strokeLinecap="round" strokeLinejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
        </svg>
        Free interactive programming tutorials
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-hero-display font-semibold text-black dark:text-white leading-[1.05] tracking-tight mb-6 text-balance max-w-4xl mx-auto">
        Master <span class="text-brand-green">Programming</span><br />
        <span class="text-black dark:text-white">with Hands-on Tutorials</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mb-8 leading-relaxed">
        Learn web development, DSA, cloud computing, and embedded/IoT through interactive tutorials, quizzes, exercises, and cheatsheets. Built for beginners and professionals alike.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#courses" class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-black dark:bg-brand-green dark:text-black rounded-full hover:bg-gray-800 dark:hover:bg-brand-green-deep transition-colors">
          Explore Courses
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="m4.5 5.25 7.5 7.5 7.5-7.5m-15 6 7.5 7.5 7.5-7.5" />
          </svg>
        </a>
        <a href="https://lab.learncode.live" target="_blank" class="inline-flex items-center px-6 py-3 text-sm font-medium text-black dark:text-white border border-gray-200 dark:border-gray-700 rounded-full hover:bg-gray-50 dark:hover:bg-white/10 transition-colors">
          Try Coding Lab
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="mb-16 lg:mb-24">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map((stat) => (
        <div key={stat.label} class="text-center p-6 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50/50 dark:bg-white/[0.02]">
          <div class="text-2xl sm:text-3xl font-bold text-black dark:text-white">{stat.value}</div>
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Courses -->
  <section id="courses" class="mb-16 lg:mb-24">
    <div class="text-center mb-10">
      <h2 class="text-heading-2 text-black dark:text-white mb-3">Explore Our Courses</h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">Structured learning paths across multiple domains. Each course includes tutorials, exercises, and quizzes.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {categories.map((cat) => (
        <div
          key={cat.slug}
          class="group relative bg-white dark:bg-transparent border border-gray-200 dark:border-gray-800 rounded-xl p-6 hover:border-brand-green/30 hover:shadow-brand-glow dark:hover:border-brand-green/20 dark:hover:bg-white/[0.02] transition-all duration-200"
        >
          <div class="w-10 h-10 rounded-lg bg-brand-green/10 flex items-center justify-center mb-4 group-hover:bg-brand-green/20 transition-colors">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
              <path strokeLinecap="round" strokeLinejoin="round" d={cat.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-black dark:text-white mb-2 group-hover:text-brand-green-deep dark:group-hover:text-brand-green transition-colors">
            {cat.name}
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 leading-relaxed">{cat.desc}</p>
          {/* <span class="text-xs text-gray-400 dark:text-gray-500">{cat.count} tutorials</span> */}
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="mb-16 lg:mb-24">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-heading-3 text-black dark:text-white">Latest Tutorials</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Recently published content across all topics</p>
      </div>
      <a href="#courses" class="text-sm font-medium text-brand-green-deep dark:text-brand-green hover:text-brand-green transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="grid sm:grid-cols-2 gap-5">
      {posts.slice(0, 6).map((post) => (
        <ArticleCard key={post.slug} post={post} />
      ))}
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="mb-16 lg:mb-24 p-8 lg:p-12 border border-gray-200 dark:border-gray-800 rounded-2xl bg-gray-50/50 dark:bg-white/[0.02]">
    <div class="text-center mb-10">
      <h2 class="text-heading-2 text-black dark:text-white mb-3">Why Choose LearnCode.live?</h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">We make learning programming practical, accessible, and enjoyable.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: 'Hands-on Learning', desc: 'Every tutorial includes live code playgrounds so you can practice while you learn.', icon: 'M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z' },
        { title: 'Structured Curriculum', desc: 'Courses organized into chapters with clear progression from basics to advanced topics.', icon: 'M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25' },
        { title: 'Always Free', desc: 'All tutorials, exercises, and resources are completely free — no paywalls, no subscriptions.', icon: 'M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3' },
        { title: 'Modern Topics', desc: 'Covering the latest in web development, cloud computing, IoT, and AI-ready programming skills.', icon: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z' },
        { title: 'Interactive Quizzes', desc: 'Test your knowledge with quizzes and exercises after each chapter to reinforce learning.', icon: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z' },
        { title: 'Community Driven', desc: 'Content is refined through community feedback. Contributions and suggestions are always welcome.', icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z' },
      ].map((item) => (
        <div key={item.title} class="p-5">
          <div class="w-9 h-9 rounded-lg bg-brand-green/10 flex items-center justify-center mb-3">
            <svg class="w-4.5 h-4.5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
              <path strokeLinecap="round" strokeLinejoin="round" d={item.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-black dark:text-white mb-1">{item.title}</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials -->
  <section class="mb-16 lg:mb-24">
    <div class="text-center mb-10">
      <h2 class="text-heading-2 text-black dark:text-white mb-3">What Learners Say</h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">Join thousands of learners who are advancing their skills.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {[
        { quote: 'The structured approach made learning web development so much easier. Each chapter builds on the previous one perfectly.', name: 'Priya S.', role: 'CS Student' },
        { quote: 'I went from knowing nothing about IoT to building my own ESP32 projects. The hands-on tutorials are incredible.', name: 'Rahul M.', role: 'Hobbyist' },
        { quote: 'Best free resource for DSA preparation. The code playground feature helps me practice algorithms in real-time.', name: 'Ankit K.', role: 'Software Developer' },
      ].map((t) => (
        <div key={t.name} class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-white dark:bg-transparent hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-card dark:hover:shadow-none dark:hover:bg-white/[0.02] transition-all duration-200">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map((_, i) => (
              <svg key={i} class="w-4 h-4 text-brand-green" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-4">"{t.quote}"</blockquote>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-green to-brand-green-deep flex items-center justify-center text-xs font-bold text-white dark:text-black">
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="text-sm font-medium text-black dark:text-white">{t.name}</div>
              <div class="text-xs text-gray-400 dark:text-gray-500">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="p-8 lg:p-12 bg-gradient-to-br from-black to-gray-900 dark:from-brand-green/20 dark:to-brand-green/5 rounded-2xl text-center mb-8">
    <h2 class="text-heading-2 text-white dark:text-white mb-3">Ready to Start Learning?</h2>
    <p class="text-lg text-gray-400 dark:text-gray-300 max-w-xl mx-auto mb-6">Join thousands of learners mastering programming skills for free.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="#courses" class="inline-flex items-center px-6 py-3 text-sm font-medium text-black bg-white dark:bg-white dark:text-black rounded-full hover:bg-gray-100 transition-colors">
        Browse Courses
        <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
          <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
