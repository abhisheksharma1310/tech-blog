{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "react",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "types": ["node"],
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
